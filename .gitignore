# ───────────── Data (1.6 GB — fetched separately from Zenodo) ─────────────
data/*.h5
data/.DS_Store

# ───────────── Virtual environments (rebuilt per machine) ─────────────
particle/
particle_venv/
venv/
.venv/

# ───────────── Python cruft ─────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ───────────── Training artifacts (all regenerated by the pipeline) ─────────────
# Exclude every run-state file so a fresh clone is fully reproducible.
# (Example plots under results/plots/ are kept so GitHub shows them.)
results/models/
results/predictions/
results/study_predictions/
results/*.json
results/*.csv
results/*_history.json
results/*_log.txt
results/pipeline_log.txt
results/watchdog_log.txt
results/calibration_table.tex
results/comparison_table.tex

# ───────────── LaTeX build by-products ─────────────
docs/**/*.aux
docs/**/*.log
docs/**/*.out
docs/**/*.toc
docs/**/*.lof
docs/**/*.lot
docs/**/*.fls
docs/**/*.fdb_latexmk
docs/**/*.synctex.gz
docs/**/*.bbl
docs/**/*.blg
docs/**/*.bak

# ───────────── OS noise ─────────────
.DS_Store
*.swp
